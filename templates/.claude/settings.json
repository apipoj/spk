{
  "hooks": {
    "PreToolUse": [
      ".claude/hooks/PreToolUse/wiki-secret-scan.cjs",
      ".claude/hooks/PreToolUse/gitignore-guard.cjs"
    ],
    "PostToolUse": [
      ".claude/hooks/PostToolUse/auto-ingest.cjs"
    ]
  },
  "env": {
    "SPK_AUTO_INGEST": "drop",
    "SPK_WIKI_SECRETS_STRICT": "true"
  },
  "spk": {
    "version": "3.0.2",
    "wikiRoot": "ai_context/wiki",
    "sourcesRoot": "ai_context/sources"
  }
}
